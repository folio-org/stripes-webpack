# Vite Environment Variables
# Copy this file to .env and customize for your environment

# Okapi backend server URL
VITE_OKAPI_URL=http://localhost:9130

# Okapi tenant
VITE_OKAPI_TENANT=supertenant

# Development server port
VITE_PORT=3000

# Development server host
VITE_HOST=localhost

# API endpoint
VITE_API_URL=http://localhost:9130

# Debug mode (shows additional logging)
VITE_DEBUG=true

# Application environment
# Vite automatically sets: import.meta.env.DEV, import.meta.env.PROD, import.meta.env.MODE
